{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/notification-system/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/notification-system/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/notification-system",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "email-services": {
      "type": "application",
      "root": "apps/email-services",
      "entryFile": "main",
      "sourceRoot": "apps/email-services/src",
      "compilerOptions": {
        "tsConfigPath": "apps/email-services/tsconfig.app.json"
      }
    },
    "notification-services": {
      "type": "application",
      "root": "apps/notification-services",
      "entryFile": "main",
      "sourceRoot": "apps/notification-services/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-services/tsconfig.app.json"
      }
    },
    "notification-system": {
      "type": "application",
      "root": "apps/notification-system",
      "entryFile": "main",
      "sourceRoot": "apps/notification-system/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-system/tsconfig.app.json"
      }
    },
    "push-services": {
      "type": "application",
      "root": "apps/push-services",
      "entryFile": "main",
      "sourceRoot": "apps/push-services/src",
      "compilerOptions": {
        "tsConfigPath": "apps/push-services/tsconfig.app.json"
      }
    },
    "sms-services": {
      "type": "application",
      "root": "apps/sms-services",
      "entryFile": "main",
      "sourceRoot": "apps/sms-services/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sms-services/tsconfig.app.json"
      }
    }
  }
}